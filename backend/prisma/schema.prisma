// ArchiveApp Prisma schema — Sprint 1 (MVP dátový model)
// Bližší popis polí v PROJECT.md §4.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  NA_MIESTE
  VYNESENE
  NEZNAME
}

enum OcrStatus {
  PENDING
  DONE
  FAILED
}

// Sprint 6: rozlíšenie fotky štítku (vstup do OCR pipeline) od vizuálnej
// referencie celej položky (krabica/paleta). OVERVIEW fotky preskočia OCR
// (viď services/ocr.ts) a v admin štatistikách sa nepočítajú.
enum PhotoType {
  LABEL
  OVERVIEW
}

enum QrStatus {
  FREE
  ASSIGNED
}

model ItemType {
  code  String @id
  label String
}

model Item {
  id                  String    @id @default(uuid())
  level               Int
  kind                String
  name                String
  name_source         String    @default("GENERATED")
  ocr_name_suggestion String?   @db.Text
  type_code           String?
  auto_name           String?
  parent_id           String?
  qr_code             String?   @unique
  note                String?   @db.Text
  status              Status    @default(NA_MIESTE)
  metadata            Json      @default("{}")
  metadata_status     String    @default("NONE")
  deleted_at          DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  parent   Item?   @relation("ItemTree", fields: [parent_id], references: [id])
  children Item[]  @relation("ItemTree")
  qr_tag   QRTag?
  photos   Photo[]

  @@index([level])
  @@index([kind])
  @@index([parent_id])
  @@index([type_code])
  @@index([metadata_status])
  @@index([deleted_at])
}

model QRTag {
  id               String   @id @default(uuid())
  code             String   @unique
  status           QrStatus @default(FREE)
  assigned_item_id String?  @unique
  created_at       DateTime @default(now())

  assigned_item Item? @relation(fields: [assigned_item_id], references: [id])
}

model Photo {
  id           String    @id @default(uuid())
  item_id      String
  storage_key  String
  ocr_raw_text String?
  ocr_status   OcrStatus @default(PENDING)
  photo_type   PhotoType @default(LABEL)
  created_at   DateTime  @default(now())
  deleted_at   DateTime?

  item Item @relation(fields: [item_id], references: [id])

  @@index([item_id])
  @@index([ocr_status])
  @@index([deleted_at])
  @@index([photo_type])
}
